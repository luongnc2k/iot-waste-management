    {
      "title": "Trạng thái thiết bị theo thùng (lock/compactor/buzzer/dispatch)",
      "type": "table",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_iot"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_iot"
          },
          "refId": "A",
          "query": "from(bucket: \"iot\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"actuator_status\")\n  |> last()\n  |> keep(columns: [\"bin_id\", \"_field\", \"_value\"])\n  |> pivot(rowKey: [\"bin_id\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group()"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "off",
                  "color": "green"
                },
                "1": {
                  "text": "on",
                  "color": "red"
                }
              }
            }
          ],
          "custom": {
            "align": "center"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "description": "Trạng thái mới nhất của 4 cơ cấu chấp hành cho từng thùng."
    },
    {
      "title": "Số event theo thời gian (bin_full / fire_risk / ...)",
      "type": "timeseries",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_iot"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_iot"
          },
          "refId": "A",
          "query": "from(bucket: \"iot\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"gateway_events\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"event_type\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"event_type\"])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "${__field.labels.event_type}",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "description": "Đếm số event theo cửa sổ thời gian, tách theo loại event."
    },
    {
      "title": "Thùng cần thu gom hiện tại (fill_level > 85)",
      "type": "table",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_iot"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_iot"
          },
          "refId": "A",
          "query": "from(bucket: \"iot\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r._measurement == \"bin_telemetry\" and r._field == \"fill_level\")\n  |> last()\n  |> filter(fn: (r) => r._value > 85.0)\n  |> keep(columns: [\"bin_id\", \"_value\"])\n  |> rename(columns: {_value: \"fill_level\"})\n  |> group()\n  |> sort(columns: [\"fill_level\"], desc: true)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "description": "Suy từ InfluxDB: các thùng có mức đầy mới nhất vượt ngưỡng thu gom 85%."
    },
    {
      "title": "Event gần nhất",
      "type": "table",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb_iot"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb_iot"
          },
          "refId": "A",
          "query": "from(bucket: \"iot\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"gateway_events\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\", \"bin_id\", \"event_type\", \"severity\", \"value\", \"threshold\"])\n  |> group()\n  |> sort(columns: [\"_time\"], desc: true)\n  |> limit(n: 30)"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "severity"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "color": "red",
                        "index": 0
                      },
                      "warning": {
                        "color": "orange",
                        "index": 1
                      },
                      "info": {
                        "color": "blue",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ]
      },
      "description": "20–30 event gần nhất kèm severity, value, threshold."
    }
  ]
}