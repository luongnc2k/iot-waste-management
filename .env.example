# MQTT Broker
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Publish interval (giây)
PUBLISH_INTERVAL=5

# ThingsBoard (dùng cho SV3)
TB_HOST=thingsboard.cloud
TB_PORT=1883
TB_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN_HERE

# InfluxDB (dùng cho SV2)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=dev-token-change-me
INFLUXDB_ORG=hust
INFLUXDB_BUCKET=iot
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345

# Edge Gateway — ngưỡng rule engine (SV2)
FILL_DISPATCH_THRESHOLD=85
FILL_CRITICAL_THRESHOLD=95
TEMP_FIRE_THRESHOLD=60
METHANE_ALERT_THRESHOLD=500
WEIGHT_LOCK_THRESHOLD=60
SENSOR_OFFLINE_TIMEOUT=30
COLLECTION_DELAY=20

# REST API + Grafana (SV3)
BIN_IDS=bin-01,bin-02,bin-03
