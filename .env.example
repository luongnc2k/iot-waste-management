# MQTT Broker
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=iot_user
MQTT_PASS=iot_pass_2026

# Khu vực + danh tính gateway
AREA_ID=district-1
GATEWAY_ID=waste-gateway

# Publish interval (giây)
PUBLISH_INTERVAL=5
# bin-03 dùng chu kỳ khác để 3 thùng lệch pha
PUBLISH_INTERVAL_BIN03=7

# ThingsBoard (dùng cho SV3)
TB_HOST=thingsboard.cloud
TB_PORT=1883
TB_GATEWAY_TOKEN=YOUR_GATEWAY_TOKEN_HERE

# InfluxDB (dùng cho SV2)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=dev-token-change-me
INFLUXDB_ORG=hust
INFLUXDB_BUCKET=iot
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345

# Edge Gateway — ngưỡng rule engine (SV2)
FILL_DISPATCH_THRESHOLD=85
FILL_CRITICAL_THRESHOLD=95
TEMP_FIRE_THRESHOLD=60
METHANE_ALERT_THRESHOLD=500
WEIGHT_LOCK_THRESHOLD=70
SENSOR_OFFLINE_TIMEOUT=30
COLLECTION_DELAY=60

# REST API + Grafana (SV3)
BIN_IDS=bin-01,bin-02,bin-03
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Webhook thông báo sự kiện critical (§5.17.5) — bỏ trống để tắt
# Tương thích: Slack Incoming Webhook, Discord Webhook, webhook.site, n8n, ...
# Ví dụ nhanh để test: tạo URL miễn phí tại https://webhook.site rồi paste vào đây
WEBHOOK_URL=
# Gửi webhook cho severity nào: "critical" | "warning" | "all"
WEBHOOK_SEVERITY=critical
